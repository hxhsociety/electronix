{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ElectroniX",
  "version": "0.1.3",
  "identifier": "com.hxhsociety.electronix",

  "build": {
    "beforeDevCommand": "npm --prefix frontend run dev",
    "beforeBuildCommand": "npm --prefix frontend run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },

  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ElectroniX — Reliability Workbench",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost asset: http://asset.localhost https://asset.localhost; img-src 'self' data: blob: asset: http://asset.localhost https://asset.localhost; media-src 'self' asset: http://asset.localhost https://asset.localhost; model-src 'self' asset: http://asset.localhost https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'wasm-unsafe-eval'; worker-src 'self' blob:",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "deny": []
        }
      }
    },
    "withGlobalTauri": true
  },

  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ5MDQwQkYyQ0FDNTc4MUUKUldRZWVNWEs4Z3NFMlQ4bmtQMllZQTQxamIwTEx2T25qb1Q5elYrSVlXZjJsVFBscHBtMm9QQjUK",
      "endpoints": [
        "https://github.com/HxHSociety/ElectroniX/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "headers": {
        "Accept": "application/octet-stream"
      }
    }
  },

  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/gltf_convertor",
      "binaries/rpim_pc",
      "binaries/rpim_solver"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "ElectroniX",
    "copyright": "© 2026 ElectroniX. All rights reserved.",
    "category": "DeveloperTool",
    "shortDescription": "PCB solder joint fatigue and thermal reliability analysis",
    "longDescription": "ElectroniX Reliability Workbench — physics-based solder fatigue life prediction using Anand viscoplastic creep and Darveaux energy partitioning. Supports SAC305, SAC405, SnPb37. Thermal cycling profiles per JEDEC, IPC-9701, MIL-STD-810, and custom curves.",
    "windows": {
      "nsis": {
        "languages": ["English"],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      },
      "wix": null
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
