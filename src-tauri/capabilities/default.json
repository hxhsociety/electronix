{
  "$schema": "https://schema.tauri.app/capability/2",
  "identifier": "default",
  "description": "Default ElectroniX capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:allow-read",
      "scope": ["$APPDATA/ElectroniX/**"]
    },
    {
      "identifier": "fs:allow-write",
      "scope": ["$APPDATA/ElectroniX/**"]
    }
  ]
}
